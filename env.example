# ============================================
# SERVER CONFIGURATION (WYMAGANE)
# ============================================
# Port na którym działa backend API
PORT=5000

# MongoDB connection string
# Format: mongodb://[username:password@]host[:port][/database][?options]
# Przykład dla lokalnego: mongodb://127.0.0.1:27017/helpfli
# Przykład dla Atlas: mongodb+srv://user:pass@cluster.mongodb.net/helpfli
MONGO_URI=mongodb://127.0.0.1:27017/helpfli

# Secret key dla JWT tokens (WYMAGANE W PRODUKCJI!)
# Użyj długiego, losowego stringa (min. 32 znaki)
# Wygeneruj: openssl rand -base64 32
JWT_SECRET=supersecret

# URL frontendu (używane w emailach i linkach)
CLIENT_URL=http://localhost:5174

# URL backendu (używane w webhookach i linkach)
SERVER_URL=http://localhost:5000

# Pliki zleceń (załączniki), KYC, czat — domyślnie backend/uploads. Na produkcji ustaw trwały wolumen (Docker/K8s),
# inaczej po restarcie kontenera pliki znikną (404 przy /uploads/orders/...).
# UPLOAD_DIR=/var/data/uploads
# KYC: max rozmiar jednego pliku (MB). Reverse proxy (nginx/Caddy) musi mieć client_max_body_size >= sumy uploadów.
# MAX_FILE_SIZE_MB=10

# URL frontendu dla powiadomień (jeśli różny od CLIENT_URL)
FRONTEND_URL=http://localhost:5174

# Ukryj zlecenia i oferty kont seed (@helpfli.test, @*.local) przed zwykłymi użytkownikami (domyślnie włączone).
# Ustaw 0 tylko lokalnie, jeśli testujesz pełnym seedem.
# HIDE_DEMO_DATA=0

# ============================================
# STRIPE CONFIGURATION (WYMAGANE dla płatności)
# ============================================
# Pobierz klucze z: https://dashboard.stripe.com/apikeys
# Test keys zaczynają się od sk_test_ i pk_test_
# Production keys zaczynają się od sk_live_ i pk_live_
STRIPE_SECRET_KEY= your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY= your_stripe_publishable_key

# Webhook secret (pobierz z Stripe Dashboard > Webhooks)
# Używane do weryfikacji webhooków od Stripe
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Cenniki (utwórz Produkty + Prices w Stripe i wklej ID):
STRIPE_PRICE_PROMO_24H=price_test_24h
STRIPE_PRICE_PROMO_TOP7=price_test_7d
STRIPE_PRICE_PROMO_TOP14=price_test_14d
STRIPE_PRICE_PROMO_TOP31=price_test_31d

STRIPE_PRICE_PRO_MONTHLY=price_test_pro_m
STRIPE_PRICE_PRO_YEARLY=price_test_pro_y

# Web Push (VAPID) - wygeneruj: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BOgTest...
VAPID_PRIVATE_KEY=abcTest...
VAPID_SUBJECT=mailto:admin@helpfli.app

# Transactional Email (preferred): Resend
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Helpfli <helpfli@outlook.com>
CONTACT_EMAIL=helpfli@outlook.com
# Faktury VAT od Helpfli (subskrypcje, boosty) — ustaw true gdy masz firmę i NIP
PLATFORM_INVOICING_ENABLED=false
INVOICE_SELLER_NAME=Helpfli
INVOICE_SELLER_NIP=

# SMTP fallback (optional; used only when RESEND_API_KEY is not set)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Cache settings
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=600
CACHE_PREFIX=helpfli:

# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=eu-central-1
# Główny bucket (uploady, chat). Health /api/health akceptuje też AWS_S3_BUCKET jeśli ustawiony zamiast tego.
AWS_BUCKET_NAME=helpfli-uploads
# AWS_S3_BUCKET=

# CORS - comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5174

# OneSignal (optional)
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key

# AI/LLM Configuration
LLM_PROVIDER=auto
LLM_FALLBACK_ENABLED=true

# Hybrydowy router: gemini (tani) → claude (smart) przy słabej odpowiedzi
# hybrid | claude | gemini  (domyślnie hybrid gdy są oba klucze)
AI_ROUTER_MODE=hybrid
AI_CHEAP_MODEL=gemini-2.0-flash
AI_SMART_MODEL=claude-haiku-4-5-20251001

# Gość: darmowe zapytania AI przed rejestracją (liczone po stronie serwera, nagłówek X-Guest-Id)
GUEST_AI_QUERY_LIMIT=10
GUEST_AI_WARN_AT=8
GUEST_AI_IP_DAILY_CAP=30
# CLIENT_FREE_AI_MONTHLY_LIMIT=50

# Google Gemini (tani tier — klasyfikacja, brief, proste odpowiedzi)
GEMINI_API_KEY=your-gemini-api-key-here

# Claude 3.5 API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Ollama Local LLM (fallback)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5vl

# Web Search Configuration
WEB_SEARCH_PROVIDER=bing
WEB_SEARCH_FALLBACK_ENABLED=true

# Bing Search API
BING_API_KEY=your-bing-search-api-key

# SerpAPI (Google Search)
SERPAPI_KEY=your-serpapi-key

# Perplexity API
PERPLEXITY_API_KEY=your-perplexity-api-key

# Production Monitoring & Logging
# SENTRY_DSN=   # optional; set only your real DSN — leave unset to disable (do not use placeholder URLs)
NODE_ENV=development

# Rate limiting (produkcja — domyślne limity w middleware/rateLimiter.js)
# AUTH_RATE_LIMIT_MAX=30
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# API_RATE_LIMIT_MAX=400
# API_RATE_LIMIT_WINDOW_MS=900000
# REGISTER_RATE_LIMIT_MAX=10
# REGISTER_RATE_LIMIT_WINDOW_MS=3600000
# Zaufane IP (np. biuro) — pomijane przez część limiterów, lista po przecinku
# TRUSTED_IPS=1.2.3.4

# Backup Configuration
BACKUP_DIR=./backups
MAX_BACKUPS=7

# SMS Configuration
SMS_PROVIDER=smsapi
# SMSAPI.pl
SMSAPI_TOKEN=your-smsapi-token
SMSAPI_SENDER=Helpfli
# Twilio (alternatywa)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+48123456789
BACKUP_COMPRESSION=true
BACKUP_SCHEDULE=0 2 * * *
AWS_S3_BACKUP_BUCKET=helpfli-backups

# Tryb „Pozyskaj tylko oferty” — opłata za odblokowanie kontaktu po wyborze wykonawcy (PLN). CLIENT_PRO: gratis.
# OFFERS_ONLY_CONTACT_UNLOCK_PLN=24
# Opcjonalne boosty przy wystawieniu (offers_only). CLIENT_PRO: Fast Track gratis.
# OFFERS_ONLY_FAST_TRACK_PLN=19
# OFFERS_ONLY_LIST_HIGHLIGHT_PLN=9
# OFFERS_ONLY_VERIFIED_ONLY_PLN=29

# Program Founding Provider — cron przypomnień (7/3/1/0 dni) i wygaszania statusu
# Na stałym serwerze: ENABLE_JOBS=1 (node-cron w server.js)
# Na Vercel/serverless: ustaw CRON_SECRET i zaplanuj POST /api/growth/cron-webhook (vercel.json crons)
# ENABLE_JOBS=1
# ENABLE_FOUNDING_PROVIDER_CRON=true
# FOUNDING_PROVIDER_CRON=10 9 * * *
# CRON_SECRET=wygeneruj-dlugim-losowym-stringiem

# ============================================
# AI COMMAND CENTER — Marketing Read API (service-to-service)
# ============================================
# Token read-only dla integracji z AI Command Center (min. 32 znaki losowe).
# AI_COMMAND_CENTER_READ_TOKEN=wygeneruj-dlugim-losowym-stringiem
# Opcjonalna lista IP (po przecinku) — tylko jeśli proxy przekazuje prawdziwe IP.
# AI_COMMAND_CENTER_ALLOWED_IPS=
# Limit zapytań na minutę (domyślnie 60).
# AI_COMMAND_CENTER_RATE_LIMIT=60
# AI_COMMAND_CENTER_RATE_LIMIT_WINDOW_MS=60000
# MARKETING_INTEGRATION_PRIVACY_MIN_COUNT=5
# MARKETING_INTEGRATION_MAX_DATE_RANGE_DAYS=90
# MARKETING_INTEGRATION_MAX_CATEGORIES=20
# MARKETING_INTEGRATION_MAX_LOCATIONS=20
# MARKETING_INTEGRATION_CACHE_TTL_SECONDS=300
# MARKETING_INTEGRATION_MAX_RESPONSE_BYTES=1048576

# ============================================
# AI SEO ENGINE — Poradniki AI (/poradnik/:slug)
# ============================================
# Bazowy URL używany w sitemap.xml i kanonicznych linkach poradników.
# Ustaw zawsze w produkcji – inaczej będzie używany default „https://helpfli.pl".
# SEO_PUBLIC_BASE_URL=https://helpfli.pl

# Czy uruchamiać nocny cron generujący nowe poradniki (wymaga ENABLE_JOBS=1).
# Zalecane: generuj jako drafty i przeglądaj ręcznie (Google lubi jakość).
# SEO_AUTO_GENERATE=0

# Harmonogram cronu (cron syntax). Domyślnie codziennie 03:30.
# SEO_CRON_SCHEDULE=30 3 * * *

# Strefa czasowa cronu.
# SEO_CRON_TZ=Europe/Warsaw

# Liczba poradników generowanych na noc.
# SEO_CRON_COUNT=5

# Czy cron ma od razu publikować (1) czy zostawiać jako drafty (0, default).
# SEO_CRON_AUTO_PUBLISH=0

# Twarda granica liczby artykułów w bazie – cron wyłącza się powyżej.
# SEO_CRON_HARD_CAP=500

# ============================================
# PSEO — landingi /wykonawcy/:service/:city
# ============================================
# Limit par na jedno żądanie bulk-build (admin API).
# PSEO_BULK_MAX_PAIRS=15

# Cron budowy brakujących stron PSEO (włącz na produkcji).
# Uruchamiany przez POST /api/growth/cron-webhook (vercel.json) gdy PSEO_CRON_ENABLED=1.
# PSEO_CRON_ENABLED=1
# PSEO_CRON_MAX_BUILD=8
# PSEO_CRON_CITY_LIMIT=12
# PSEO_CRON_SERVICE_LIMIT=8

# Edge Middleware frontendu (Vercel): URL prerenderu dla botów SEO.
# PRERENDER_API_URL=https://api.helpfli.pl/api/seo/prerender

# Limity URL-i w sitemap.xml (profile wykonawców + katalog usług).
# SITEMAP_MAX_PROVIDERS=500
# SITEMAP_MAX_SERVICES=500

# CSRF (double-submit cookie) — opcjonalnie dla formularzy HTML bez JWT.
# API z Bearer token pomija CSRF. Token: GET /api/health/csrf-token
# ENABLE_CSRF=0

# ============================================
# FAZA 2 — INDEXNOW (Bing / Yandex / DuckDuckGo)
# ============================================
# Klucz IndexNow (UUID lub 8–128 hex). Generuj raz, zachowaj na zawsze.
# Po ustawieniu, backend wystawia plik weryfikujący pod https://helpfli.pl/<KEY>.txt
# Wytyczne: https://www.indexnow.org/documentation
# INDEXNOW_KEY=

# Opcjonalny kill-switch (1 lub 0). Domyślnie auto-ON jeśli INDEXNOW_KEY ustawione.
# INDEXNOW_ENABLED=1

