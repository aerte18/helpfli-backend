# ============================================
# SERVER CONFIGURATION (WYMAGANE)
# ============================================
# Port na ktĂłrym dziaĹ‚a backend API
PORT=5000

# MongoDB connection string
# Format: mongodb://[username:password@]host[:port][/database][?options]
# PrzykĹ‚ad dla lokalnego: mongodb://127.0.0.1:27017/helpfli
# PrzykĹ‚ad dla Atlas: mongodb+srv://user:pass@cluster.mongodb.net/helpfli
MONGO_URI=mongodb://127.0.0.1:27017/helpfli

# Secret key dla JWT tokens (WYMAGANE W PRODUKCJI!)
# UĹĽyj dĹ‚ugiego, losowego stringa (min. 32 znaki)
# Wygeneruj: openssl rand -base64 32
JWT_SECRET=supersecret

# URL frontendu (uĹĽywane w emailach i linkach)
CLIENT_URL=http://localhost:5174

# URL backendu (uĹĽywane w webhookach i linkach)
SERVER_URL=http://localhost:5000

# URL frontendu dla powiadomieĹ„ (jeĹ›li rĂłĹĽny od CLIENT_URL)
FRONTEND_URL=http://localhost:5174

# ============================================
# STRIPE CONFIGURATION (WYMAGANE dla pĹ‚atnoĹ›ci)
# ============================================
# Pobierz klucze z: https://dashboard.stripe.com/apikeys
# Test keys zaczynajÄ… siÄ™ od sk_test_ i pk_test_
# Production keys zaczynajÄ… siÄ™ od sk_live_ i pk_live_
STRIPE_SECRET_KEY= your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY= your_stripe_publishable_key

# Webhook secret (pobierz z Stripe Dashboard > Webhooks)
# UĹĽywane do weryfikacji webhookĂłw od Stripe
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Cenniki (utwĂłrz Produkty + Prices w Stripe i wklej ID):
STRIPE_PRICE_PROMO_24H=price_test_24h
STRIPE_PRICE_PROMO_TOP7=price_test_7d
STRIPE_PRICE_PROMO_TOP14=price_test_14d
STRIPE_PRICE_PROMO_TOP31=price_test_31d

STRIPE_PRICE_PRO_MONTHLY=price_test_pro_m
STRIPE_PRICE_PRO_YEARLY=price_test_pro_y

# Web Push (VAPID) - wygeneruj: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BOgTest...
VAPID_PRIVATE_KEY=abcTest...
VAPID_SUBJECT=mailto:admin@helpfli.app

# SMTP Configuration (Gmail, Outlook, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Cache settings
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=600
CACHE_PREFIX=helpfli:

# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=eu-central-1
# Główny bucket (uploady, chat). Health /api/health akceptuje też AWS_S3_BUCKET jeśli ustawiony zamiast tego.
AWS_BUCKET_NAME=helpfli-uploads
# AWS_S3_BUCKET=

# CORS - comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5174

# OneSignal (optional)
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key

# AI/LLM Configuration
LLM_PROVIDER=auto
LLM_FALLBACK_ENABLED=true

# Claude 3.5 API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Ollama Local LLM (fallback)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5vl

# Web Search Configuration
WEB_SEARCH_PROVIDER=bing
WEB_SEARCH_FALLBACK_ENABLED=true

# Bing Search API
BING_API_KEY=your-bing-search-api-key

# SerpAPI (Google Search)
SERPAPI_KEY=your-serpapi-key

# Perplexity API
PERPLEXITY_API_KEY=your-perplexity-api-key

# Production Monitoring & Logging
# SENTRY_DSN=   # optional; set only your real DSN — leave unset to disable (do not use placeholder URLs)
NODE_ENV=development

# Backup Configuration
BACKUP_DIR=./backups
MAX_BACKUPS=7

# SMS Configuration
SMS_PROVIDER=smsapi
# SMSAPI.pl
SMSAPI_TOKEN=your-smsapi-token
SMSAPI_SENDER=Helpfli
# Twilio (alternatywa)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+48123456789
BACKUP_COMPRESSION=true
BACKUP_SCHEDULE=0 2 * * *
AWS_S3_BACKUP_BUCKET=helpfli-backups

